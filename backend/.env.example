# LocalMind backend configuration
#
# Copy this file to `.env` and adjust as needed. Never commit a real `.env`.
#
# LocalMind is model-agnostic: it talks to any OpenAI-compatible endpoint via a
# single provider abstraction (see provider.py). Dev runs entirely locally on
# Ollama (free, no keys); prod points at a hosted provider.

# Which inference provider to use: ollama | groq | openrouter | azure
# Default: ollama (fully local).
LLM_PROVIDER=ollama

# --- ollama (dev) ---
# Base URL of the local Ollama server; LocalMind uses its OpenAI-compatible
# `/v1` endpoint. IPv4 loopback avoids a Windows IPv6 (::1) stall.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- groq (prod, text-only; vision disabled) ---
GROQ_API_KEY=

# --- openrouter (prod; single provider that also serves vision) ---
OPENROUTER_API_KEY=

# --- azure (prod; deployment names live in provider.py's MODEL_MAP) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional Azure deployment-name overrides:
# AZURE_ROUTER_DEPLOYMENT=gpt-4o-mini
# AZURE_REASONING_DEPLOYMENT=gpt-4o
# AZURE_GENERAL_DEPLOYMENT=gpt-4o-mini
# AZURE_VISION_DEPLOYMENT=gpt-4o
