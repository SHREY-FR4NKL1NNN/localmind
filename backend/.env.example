# LocalMind backend configuration
#
# Copy this file to `.env` and adjust as needed. LocalMind runs entirely
# locally, so no API keys or secrets are required — the only configurable value
# is where the Ollama server is listening.

# Base URL of the local Ollama server. All inference is routed here.
# Default: http://127.0.0.1:11434
# Note: the IPv4 loopback (127.0.0.1) is used rather than "localhost" because
# on Windows "localhost" can resolve to IPv6 (::1) and stall before falling
# back to IPv4, while Ollama listens on 127.0.0.1.
OLLAMA_BASE_URL=http://127.0.0.1:11434
